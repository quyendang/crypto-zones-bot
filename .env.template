############################
# Crypto Zones Bot - .env
# Copy to ".env" and fill in
############################

# Exchange & markets
EXCHANGE=binance
QUOTE=USDT
# Comma-separated list of base symbols
SYMBOLS=BTC,ETH
# Comma-separated list of timeframes (ccxt format)
TIMEFRAMES=4h,1d

# How often to refresh market data (seconds)
UPDATE_SECONDS=20

# Strategy mode: GROW_USDT or ACCUMULATE_COIN
MODE=GROW_USDT

# Risk knobs
ATR_MULT_STOP=1.8
Z_ENTRY=1.2
Z_EXIT=0.3
RSI_LOW=35
RSI_HIGH=65

# Trend filters
SMA_FAST=20
SMA_SLOW=50
SMA_TREND=200

# Trading bot & database
# Replace with your actual Postgres connection string
# Example:
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=

# Interval between trade decisions (seconds) – default 300s = 5 minutes
TRADE_INTERVAL_SECONDS=300

# Minimum price distance between two BUY orders (USD)
MIN_DIFF_ETH=100
MIN_DIFF_BTC=2000

